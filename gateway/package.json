{
  "name": "lookup-gateway",
  "version": "1.0.0",
  "description": "Local gateway for LookUp - Personal Study Sensei",
  "main": "index.js",
  "bin": "bundle.cjs",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "build:bundle": "node build.js",
    "build:exe": "pkg . --output ../dist/LookUp.exe",
    "build": "npm run build:bundle && npm run build:exe",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fs-extra": "^11.2.0",
    "groq-sdk": "^0.9.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0",
    "esbuild": "^0.27.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  },
  "pkg": {
    "targets": [
      "node22-win-x64"
    ],
    "assets": [
      "node_modules/better-sqlite3/**"
    ],
    "outputPath": "../dist"
  }
}
