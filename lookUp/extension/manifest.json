{
  "manifest_version": 3,
  "name": "LookUp — Study Sensei",
  "version": "1.0.0",
  "description": "Capture your screen on-demand for AI-powered summaries, formulas, and Q&A.",

  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "scripting",
    "tabCapture"
  ],

  "host_permissions": [
    "http://127.0.0.1:18789/*",
    "<all_urls>"
  ],

  "action": {
    "default_title": "Open LookUp"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
