<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LookUp</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0f0f13;
      color: #e8e8f0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      padding: 16px;
      border-bottom: 1px solid #1e1e2e;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    header h1 {
      font-size: 18px;
      font-weight: 700;
      background: linear-gradient(135deg, #7c6af5, #5eead4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #ef4444;
      margin-left: auto;
      transition: background 0.3s;
    }
    .status-dot.online { background: #22c55e; }

    .mode-selector {
      display: flex;
      gap: 6px;
      padding: 12px 16px;
      border-bottom: 1px solid #1e1e2e;
    }

    .mode-btn {
      flex: 1;
      padding: 7px 4px;
      font-size: 11px;
      font-weight: 600;
      border: 1px solid #2a2a3e;
      border-radius: 8px;
      background: transparent;
      color: #888;
      cursor: pointer;
      transition: all 0.2s;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .mode-btn.active {
      background: #7c6af5;
      border-color: #7c6af5;
      color: #fff;
    }

    .mode-btn:hover:not(.active) {
      border-color: #7c6af5;
      color: #ccc;
    }

    .title-input {
      margin: 12px 16px;
    }

    .title-input input {
      width: 100%;
      padding: 8px 12px;
      background: #1a1a2e;
      border: 1px solid #2a2a3e;
      border-radius: 8px;
      color: #e8e8f0;
      font-size: 13px;
      outline: none;
      transition: border-color 0.2s;
    }

    .title-input input:focus { border-color: #7c6af5; }
    .title-input input::placeholder { color: #555; }

    .capture-btn {
      margin: 0 16px 16px;
      width: calc(100% - 32px);
      padding: 12px;
      font-size: 14px;
      font-weight: 700;
      border: none;
      border-radius: 10px;
      background: linear-gradient(135deg, #7c6af5, #5eead4);
      color: #fff;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }

    .capture-btn:hover { opacity: 0.9; }
    .capture-btn:active { transform: scale(0.98); }
    .capture-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .result-area {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
    }

    .placeholder {
      color: #444;
      font-size: 13px;
      text-align: center;
      margin-top: 40px;
      line-height: 1.6;
    }

    .result-card {
      background: #1a1a2e;
      border: 1px solid #2a2a3e;
      border-radius: 12px;
      padding: 14px;
      font-size: 13px;
      line-height: 1.6;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .result-card .saved-badge {
      display: inline-block;
      margin-bottom: 10px;
      padding: 3px 8px;
      background: #14532d;
      color: #86efac;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
    }

    .error-card {
      background: #2a1a1a;
      border: 1px solid #7f1d1d;
      border-radius: 12px;
      padding: 14px;
      font-size: 13px;
      color: #fca5a5;
    }

    .spinner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 40px 0;
      color: #7c6af5;
      font-size: 13px;
    }

    .spinner::before {
      content: "";
      width: 20px;
      height: 20px;
      border: 2px solid #2a2a3e;
      border-top-color: #7c6af5;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <header>
    <h1>LookUp</h1>
    <span style="font-size:11px;color:#555;">Study Sensei</span>
    <div class="status-dot" id="statusDot"></div>
  </header>

  <div class="mode-selector">
    <button class="mode-btn active" data-mode="summary">Summary</button>
    <button class="mode-btn" data-mode="explain">Explain</button>
    <button class="mode-btn" data-mode="quiz">Quiz</button>
  </div>

  <div class="title-input">
    <input type="text" id="titleInput" placeholder="Note title (optional)" maxlength="80" />
  </div>

  <button class="capture-btn" id="captureBtn">Capture &amp; Analyze</button>

  <div class="result-area" id="resultArea">
    <p class="placeholder">Click "Capture &amp; Analyze" to snapshot your current tab and get an AI-powered study breakdown.</p>
  </div>

  <script src="sidepanel.js"></script>
</body>
</html>
